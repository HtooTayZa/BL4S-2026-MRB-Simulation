#include "MRBDWCSD.hh"
#include "G4Step.hh"
#include "G4ThreeVector.hh"
#include "G4SystemOfUnits.hh"

MRBDWCSD::MRBDWCSD(G4String name) : G4VSensitiveDetector(name) 
{}

MRBDWCSD::~MRBDWCSD() {}

G4bool MRBDWCSD::ProcessHits(G4Step* aStep, G4TouchableHistory*)
{
    // Get energy deposited in the gas
    G4double edep = aStep->GetTotalEnergyDeposit();
    if (edep == 0.) return false; // Only record if it actually ionizes the gas

    // Get the particle name (to distinguish primary protons from secondary neutrons/pions)
    G4String particleName = aStep->GetTrack()->GetDefinition()->GetParticleName();
    
    // Get the hit position
    G4ThreeVector hitPos = aStep->GetPreStepPoint()->GetPosition();

    // For now, we print to console. Later, we will save this to a ROOT file.
    G4cout << "DWC Hit! Particle: " << particleName 
           << " | Position Z: " << hitPos.z()/cm << " cm" << G4endl;

    return true;
}
